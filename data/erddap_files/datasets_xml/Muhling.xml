    <dataVariable>
      <sourceName>SElo</sourceName>
      <destinationName>SElo</destinationName>
      <dataType>float</dataType>
      <addAttributes>
        <att name="ioos_category">Other</att>
      </addAttributes>
    </dataVariable>
  </dataset>

<?xml version="1.0" encoding="UTF-8"?>
<erddapDatasets>
  <dataset type="EDDTableFromNccsvFiles" datasetID="cciea_HMS_biomass" active="true">
    <reloadEveryNMinutes>2628000</reloadEveryNMinutes>
    <fileDir>data/erddap_files/nccsv/Muhling</fileDir>

      <att name="Other">cdm_data_type</att>
      <att name="license">[standard]</att>
      <att name="sourceUrl">(local files)</att>
      <att name="standard_name_vocabulary">CF Standard Name Table v70</att>
      <att name="subsetVariables">species_cohort</att>
    </addAttributes>
    <dataVariable>
      <sourceName>year</sourceName>
      <destinationName>time</destinationName>
      <dataType>String</dataType>
      <addAttributes>
        <att name="ioos_category">Time</att>
      </addAttributes>
    </dataVariable>
    <dataVariable>
      <sourceName>index</sourceName>
      <destinationName>density_anomaly</destinationName>
      <dataType>float</dataType>
      <addAttributes>
        <att name="ioos_category">Other</att>
      </addAttributes>
    </dataVariable>
    <dataVariable>
      <sourceName>timeseries</sourceName>
      <destinationName>indicator</destinationName>
      <dataType>String</dataType>
      <addAttributes>
        <att name="ioos_category">Other</att>
      </addAttributes>
    </dataVariable>
  </dataset>
